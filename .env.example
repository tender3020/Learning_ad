# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── DeepSeek AI ────────────────────────────────────────────────
DEEPSEEK_API_KEY=         # DeepSeek API Key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=               # JWT signing secret for phone login

# ── 火山引擎 TTS（豆包语音）────────────────────────────────────
VOLCENGINE_TTS_API_KEY=   # 火山控制台 API Key（新版控制台）
VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0
VOLCENGINE_TTS_SPEAKER=zh_female_shuangkuaisisi_moon_bigtts
VOLCENGINE_TTS_FORMAT=mp3
VOLCENGINE_TTS_SAMPLE_RATE=24000
# 旧版控制台如需使用，取消注释以下两项并填写
# VOLCENGINE_TTS_APP_ID=
# VOLCENGINE_TTS_ACCESS_KEY=

# ── 阿里云百炼 · 万相图像生成 ─────────────────────────────────
DASHSCOPE_API_KEY=         # 百炼 API Key（与地域对应，北京/新加坡不可混用）
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/api/v1
# wan2.7-image 标准版；wan2.7-image-pro 细节更好但更慢更贵
DASHSCOPE_IMAGE_MODEL=wan2.7-image
# 2K 为万相推荐分辨率；也可设为 1920*1280 等 3:2 像素值
DASHSCOPE_IMAGE_SIZE=2K
# 配图视觉校验（万相 retry）使用的多模态模型
DASHSCOPE_VISION_MODEL=qwen-vl-plus
IMAGE_VALIDATION_ENABLED=true
MERMAID_RENDER_TIMEOUT_MS=30000
